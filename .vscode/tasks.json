{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Sim",
      "type": "shell",
      "command": "python -m src",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PYTHONPATH": "${workspaceFolder}/src"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
